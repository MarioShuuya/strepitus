{
  "name": "strepitus-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "wasm:build": "cd ../crates/strepitus-core && wasm-pack build --target web --out-dir ../../web/src/wasm",
    "wasm:dev": "cd ../crates/strepitus-core && wasm-pack build --target web --dev --out-dir ../../web/src/wasm"
  },
  "dependencies": {
    "three": "^0.170.0"
  },
  "devDependencies": {
    "@types/three": "^0.170.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
